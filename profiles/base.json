{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base profile — shared across all machines",
  "description": "Dědí z něj home.json, work.json, lab.json",

  "envDir": "~/.dev-env",
  "repoDir": "~/.dev-env/repo",
  "configDir": "~/.config",
  "binDir": "~/bin",

  "tools": {
    "required": ["git"],
    "recommended": ["node", "python", "code", "gh", "pwsh", "curl", "7z"],
    "optional": ["docker", "nvim", "scoop", "nvm"]
  },

  "git": {
    "defaultBranch": "main",
    "autocrlf": "input",
    "editor": "code --wait"
  },

  "paths": {
    "maxEntries": 50,
    "required": ["%HOME%\\bin", "%SystemRoot%\\System32"],
    "forbiddenPatterns": ["OneDrive", "AppData\\Local\\Temp"]
  },

  "secrets": [
    "~/.ssh/                — SSH private keys (never commit)",
    "~/.dev-env/machines.json — Machine detection history (never commit)",
    "~/.dev-env/config/     — Local profile overrides (never commit)",
    "~/.gitconfig.user      — Personal Git identity (never commit)",
    "~/.npmrc               — NPM registry tokens (never commit)",
    "~/.aws/                — AWS credentials (never commit)",
    "~/.azure/              — Azure credentials (never commit)"
  ],

  "sync": {
    "neverCommit": [
      "~/.ssh/",
      "~/.dev-env/machines.json",
      "~/.dev-env/config/",
      "~/.gitconfig.user",
      "~/.npmrc",
      "~/.aws/",
      "~/.azure/"
    ],
    "symlink": [
      { "from": "configs/git/.gitconfig", "to": "~/.gitconfig" },
      { "from": "configs/pwsh/profile.ps1", "to": "~/.config/powershell/profile.ps1" }
    ]
  }
}
