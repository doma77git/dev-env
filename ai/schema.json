{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doma77git.github.io/dev-env/schema/report.json",
  "title": "dev-env detection report",
  "description": "Report generated by bootstrap.ps1 / bootstrap.sh — machine environment inventory.",

  "type": "object",
  "required": ["meta", "status", "fingerprint", "hostname", "username"],
  "properties": {

    "meta": {
      "type": "object",
      "description": "Metadata about this report / metadata",
      "required": ["bootstrap", "at", "repo"],
      "properties": {
        "bootstrap":  { "type": "string", "description": "Bootstrap version / verze" },
        "at":         { "type": "string", "format": "date-time", "description": "UTC timestamp" },
        "repo":       { "type": "string", "format": "uri", "description": "Source repo URL / URL repa" },
        "platform":   { "type": "string", "enum": ["windows", "linux"], "description": "OS platform" }
      }
    },

    "status": {
      "type": "string",
      "enum": ["new", "same", "os-changed", "tools-changed"],
      "description": "Detection status vs previous run / stav oproti minulému běhu"
    },

    "fingerprint": {
      "type": "string",
      "description": "SHA256(hostname|username|domain) — unique machine+user id"
    },

    "hostname":  { "type": "string" },
    "username":  { "type": "string" },
    "domain":    { "type": "string", "description": "Windows domain or 'localhost' on Linux" },

    "os": {
      "type": "object",
      "properties": {
        "caption":     { "type": "string", "description": "e.g. Microsoft Windows 11 Pro" },
        "build":       { "type": "string", "description": "Build number / číslo buildu" },
        "arch":        { "type": "string", "description": "64-bit / arm64" },
        "kernel":      { "type": "string", "description": "Kernel version (Linux) / verze jádra" },
        "installDate": { "type": "string", "format": "date" },
        "lastBoot":    { "type": "string", "format": "date" }
      }
    },

    "tools": {
      "type": "object",
      "description": "Detected tools with version and path / detekované nástroje",
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "description": "version | path   (found / nalezeno)" },
          { "type": "null",  "description": "not found / nenalezeno" }
        ]
      }
    },

    "path": {
      "type": "object",
      "properties": {
        "count":  { "type": "integer", "description": "PATH entry count / počet položek" },
        "errors": { "type": "array", "items": { "type": "string" }, "description": "Issues found / nalezené problémy" }
      }
    },

    "onedrive": {
      "type": "object",
      "description": "OneDrive status (Windows only) / stav OneDrive",
      "properties": {
        "accounts":  { "type": "object", "description": "Connected accounts / připojené účty" },
        "redirects": { "type": "object", "description": "Redirected folders / přesměrované složky" }
      }
    },

    "corporate": {
      "type": "object",
      "description": "Corporate environment signals / firemní signály",
      "properties": {
        "domainJoined": { "type": "boolean" },
        "domain":       { "type": "string" },
        "manufacturer": { "type": "string", "description": "PC manufacturer — used for VM detection" },
        "model":        { "type": "string" },
        "proxy":        { "type": ["string", "null"] }
      }
    },

    "changes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Changes since last run / změny od minulého běhu"
    }
  }
}
