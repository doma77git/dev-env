{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doma77git.github.io/dev-env/manifest.json",

  "project": "dev-env",
  "version": "1.1.1",
  "created": "2026-05-29",
  "updated": "2026-05-31",
  "entrypoint": "index.html",
  "authority": {
    "source": "https://github.com/doma77git/dev-env",
    "gist": "https://gist.github.com/doma77git/2f489d9ce5e7e0ff75b17cbe8011bbb5",
    "pages": "https://doma77git.github.io/dev-env"
  },

  "manifest": {
    "bootstrap": [
      { "file": "bootstrap.ps1", "role": "Windows PS7 entry — orchestrator (00→30→10→20→40→50→60→70)", "runtime": "irm <gist>/bootstrap.ps1 | iex" },
      { "file": "00-bootstrap-fallback.ps1", "role": "Windows PS5 entry — detect+recommend only (no auto-install)", "runtime": "powershell -c \"irm <gist>/00-bootstrap-fallback.ps1 | iex\"" },
      { "file": "bootstrap.sh",  "role": "Linux/WSL entry — orchestrator (00→30→10→20→40→50), WhatIf support",  "runtime": "DEV_ENV_WHATIF=1 curl -fsSL <gist>/bootstrap.sh | bash" }
    ],
    "profiles": [
      { "file": "profiles/base.json", "role": "Shared defaults — all profiles inherit", "extends": null },
      { "file": "profiles/home.json", "role": "Home PC — unrestricted",              "extends": "base" },
      { "file": "profiles/work.json", "role": "Corporate PC — proxy, safe mode",     "extends": "base" },
      { "file": "profiles/lab.json",  "role": "Lab VM — experimental, WSL",           "extends": "base" },
      { "file": "profiles/server.json", "role": "Server — headless, no GUI, safe mode", "extends": "base" }
    ],
    "scripts": [
      { "file": "scripts/00-core-check.ps1",       "role": "Prerequisites — PS7, git, connectivity (no install)", "runtime": "scripts/00-core-check.ps1" },
      { "file": "scripts/00-bootstrap-fallback.ps1","role": "PS5 fallback — detect→recommend→exit (no install)",  "runtime": "powershell -c \"irm <gist>/00-bootstrap-fallback.ps1 | iex\"" },
      { "file": "scripts/10-detect.ps1",            "role": "Environment inventory — fingerprint, OS, tools, PATH, OneDrive", "runtime": "scripts/10-detect.ps1" },
      { "file": "scripts/20-report.ps1",            "role": "Display report + save JSON to ~/.dev-env/", "runtime": "scripts/20-report.ps1" },
      { "file": "scripts/30-clone.ps1",             "role": "Git clone/pull (always runs — read-only)", "runtime": "scripts/30-clone.ps1" },
      { "file": "scripts/40-profile.ps1",           "role": "Profile detection (home/work/lab/server), identity", "runtime": "scripts/40-profile.ps1 [-Set home|work|lab|server]" },
      { "file": "scripts/50-setup-home.ps1",        "role": "Home PC — winget install, dirs, git config (ShouldProcess)", "runtime": "scripts/50-setup-home.ps1 [-WhatIf|-Force|-Confirm]" },
      { "file": "scripts/50-setup-lab.ps1",         "role": "Lab VM — WSL, scoop, experimental (ShouldProcess)", "runtime": "scripts/50-setup-lab.ps1 [-WhatIf|-Force|-Confirm]" },
      { "file": "scripts/50-setup-work.ps1",        "role": "Corporate PC — proxy, VPN, manual (ShouldProcess)", "runtime": "scripts/50-setup-work.ps1 [-WhatIf|-Force|-Confirm]" },
      { "file": "scripts/60-repair.ps1",            "role": "Repair PATH, HOME, OneDrive, SSH (ShouldProcess)", "runtime": "scripts/60-repair.ps1 [-WhatIf|-Force|-Confirm]" },
      { "file": "scripts/70-test.ps1",              "role": "Validate environment — 15 checks", "runtime": "scripts/70-test.ps1 (exit 0=pass)" },
      { "file": "scripts/Confirm-Action.ps1",       "role": "Interactive confirm with 10s timeout, headless detection", "runtime": ". ./scripts/Confirm-Action.ps1" },
      { "file": "scripts/link-configs.ps1",         "role": "Symlink configs from repo to ~/", "runtime": "scripts/link-configs.ps1 [-WhatIf|-Force]" },
      { "file": "scripts/undo-last.ps1",            "role": "Rollback guidance — parse last transcript log", "runtime": "scripts/undo-last.ps1 [-Pager]" }
    ],
    "configs": [
      { "file": "configs/git/.gitconfig",   "role": "Shared Git config — symlink to ~/.gitconfig" },
      { "file": "configs/pwsh/profile.ps1", "role": "PowerShell profile — starship + aliases" }
    ],
    "ai": [
      { "file": "copilot-instructions.md",        "role": "Agent instructions — hard rules, preferences, project structure" },
      { "file": "AGENTS.md",                      "role": "AI entry point — loaded by Copilot, Claude Code, Cursor, Codex" },
      { "file": ".github/copilot-instructions.md","role": "GitHub Copilot instructions — repo context, agents, prompts" },
      { "file": ".cursorrules",                   "role": "Cursor IDE rules — mirrors copilot-instructions.md" },
      { "file": "ai/context.md",                  "role": "AI context — full lifecycle, decisions, prompts, OS-independent logic" },
      { "file": "ai/copilotchat.md",              "role": "Copilot Chat conversation history and context" },
      { "file": "ai/schema.json",                 "role": "JSON Schema for bootstrap reports — AI-readable contract" }
    ],
    "docs": [
      { "file": "docs/index.md",     "role": "Landing page — GitHub Pages" },
      { "file": "docs/architecture.md", "role": "Architecture — pipeline flow, layers, rollback" },
      { "file": "docs/workflows.md", "role": "Workflows — step-by-step guides, GPG, server" }
    ],
    "menu": [
      { "file": "menu/menu.ps1", "role": "Interactive terminal menu — all actions" }
    ],
    "data": [
      { "file": "data/.gitkeep", "role": "Data exchange directory — reports, context" }
    ]
  },

  "runtime": {
    "entry": "bootstrap.ps1",
    "requires": ["pwsh 7+ (Windows)", "bash 4+ (Linux/WSL)", "irm (Windows) or curl (Linux)"],
    "flow": [
      "00 — CORE CHECK: PS7, git, connectivity → exit 1 if missing (no auto-install)",
      "30 — CLONE: git clone/pull → ~/.dev-env/repo/ (always runs, read-only)",
      "10 — DETECT: fingerprint → OS → tools → PATH → OneDrive → corporate",
      "20 — REPORT: JSON → ~/.dev-env/report-*.json + machines.json (append)",
      "40 — PROFILE: home|work|lab|server, git identity, GitHub, SSH (scripts/40-profile.ps1)",
      "50 — SETUP: packages, dirs, git config (scripts/50-setup-*.ps1, with ShouldProcess)",
      "60 — REPAIR: PATH, HOME, OneDrive, SSH (scripts/60-repair.ps1, with ShouldProcess, transcript logged)",
      "70 — TEST: 15 checks → pass/fail → exit code (scripts/70-test.ps1)"
    ]
  },

  "knowledge": {
    "concepts": [
      { "term": "bootstrap",    "def": "Self-contained detect script — first thing that runs. Never needs git." },
      { "term": "fingerprint",  "def": "SHA256(hostname|username|domain) — unique machine+user identifier." },
      { "term": "profile",      "def": "home | work | lab | server — auto-detected by domain, proxy, manufacturer, OS caption." },
      { "term": "safeMode",     "def": "Corporate/server profile — no automatic installs, always dry-run, confirm each item." },
      { "term": "machines.json","def": "Append-only history of all detections — never synced, never committed." },
      { "term": "WhatIf",       "def": "PowerShell convention — dry run, shows what WOULD happen without changing anything." },
      { "term": "ShouldProcess","def": "PowerShell advanced function — enables -WhatIf, -Confirm on every mutation." },
      { "term": "Confirm-Action","def": "10s timeout interactive prompt. Headless → auto-skip. Used in phases 50-60." }
    ],
    "secrets": [
      "~/.ssh/             — SSH keys (never commit)",
      "~/.dev-env/config/  — Local profile overrides (never commit)",
      "~/.gitconfig.user   — Personal Git identity (never commit)",
      "~/.npmrc, ~/.aws/   — Registry & cloud credentials (never commit)"
    ],
    "sync": [
      "Gist → manual copy when bootstrap logic changes (gh gist edit)",
      "Repo → git push/pull (manual or menu)",
      "~/.dev-env/repo/ → git pull (bootstrap or menu)",
      "machines.json → LOCAL ONLY — one file per machine, never shared"
    ]
  },

  "workflows": {
    "new-machine": [
      "PS7: irm <gist>/bootstrap.ps1 | iex",
      "PS5: powershell -c \"irm <gist>/00-bootstrap-fallback.ps1 | iex\"",
      "core check → clone → detect → report → profile",
      "50-setup-<profile>.ps1 -WhatIf → review → -Force (or -Confirm for per-step)",
      "60-repair.ps1 -WhatIf → review → -Force",
      "70-test.ps1 → should be all green"
    ],
    "existing-machine": [
      "irm <gist>/bootstrap.ps1 | iex (detect → same/changed)",
      "menu.ps1 → pull repo",
      "60-repair.ps1 -WhatIf → review",
      "70-test.ps1"
    ],
    "after-reinstall": [
      "irm <gist>/bootstrap.ps1 | iex (detect → os-changed)",
      "50-setup-<profile>.ps1 -Force (reinstall all)",
      "60-repair.ps1 -Force",
      "70-test.ps1"
    ]
  },

  "todo": [
    { "item": "Linux/WSL bootstrap.sh parity with .ps1", "status": "done", "desc": "v1.1.0 — WhatIf, clone→detect→report→profile→setup, home+lab+work+server." },
    { "item": "GPG commit signing guidance", "status": "done", "desc": "v1.1.0 — detection in 40-profile.ps1 for work/server, guidance in workflows." },
    { "item": "Rollback / transcript logging", "status": "done", "desc": "v1.1.0 — Start-Transcript on phases 50-60, undo-last.ps1 for guidance." },
    { "item": "CI/CD pipeline", "status": "done", "desc": "v1.1.0 — .github/workflows/ci.yml + pr.yml + gist-sync.yml." },
    { "item": "Profile JSON validation", "status": "done", "desc": "v1.1.0 — validates extends/identity/safeMode in 40-profile.ps1 + 70-test.ps1." },
    { "item": "Server setup script (50-setup-server.ps1)", "status": "done", "desc": "v1.1.0 — minimal headless server toolchain." },
    { "item": "Secrets list deduplication", "status": "done", "desc": "v1.1.0 — canonical list in profiles/base.json#/secrets, docs reference it." },
    { "item": "Interaktivní režim v setup-*.ps1", "status": "pending", "desc": "Výběr packages, identity prompt." },
    { "item": "SSH keygen prompt v setupu", "status": "pending", "desc": "Když chybí klíče, nabídnout ssh-keygen." }
  ],

  "pages": {
    "landing": {
      "url": "https://doma77git.github.io/dev-env",
      "source": "docs/index.md",
      "sections": ["about", "quickstart", "profiles", "scripts", "architecture", "workflows"]
    }
  }
}
